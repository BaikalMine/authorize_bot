BOT_TOKEN=123456:telegram-bot-token

# Optional
CAPTCHA_TIMEOUT=120s
POLLING_TIMEOUT=60
TELEGRAM_IP_FAMILY=tcp4
TELEGRAM_CONNECT_TIMEOUT=10s
TELEGRAM_REQUEST_TIMEOUT=90s
STARTUP_RETRIES=10
STARTUP_RETRY_DELAY=10s
NETWORK_DIAGNOSTICS=true
KICK_ON_TIMEOUT=true
LOG_LEVEL=info

# Optional custom Telegram Bot API endpoint. Must include two %s placeholders:
# one for token and one for method.
# TELEGRAM_API_ENDPOINT=https://api.telegram.org/bot%s/%s

# Optional proxy settings. Use these if the host or Docker network reaches
# Telegram only through a proxy.
# HTTPS_PROXY=http://host.docker.internal:1080
# HTTP_PROXY=http://host.docker.internal:1080
# NO_PROXY=localhost,127.0.0.1
